# Copy this file to `.env` (or export the vars in your shell)
# and replace placeholder values with real data.

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/recruitment
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- JWT / Security ---
# Use a long, random value in production.
JWT_SECRET=change-me-in-prod-change-me-in-prod-change-me

# --- File storage ---
CV_DIR=./storage/cv

